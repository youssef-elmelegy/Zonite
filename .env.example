# --- Backend (apps/backend) ---
# Runtime mode. Controls logger verbosity and strictness.
NODE_ENV=development

# Port the backend listens on inside its container. Exposed on the host via
# docker-compose port mapping.
PORT=3000

# Postgres connection string. Uses the compose service name "postgres" as host
# so the backend reaches the DB over the zonite-net bridge network.
DATABASE_URL=postgresql://zonite:zonite@postgres:5432/zonite

# Comma-separated list of origins allowed by the backend CORS policy.
CORS_ORIGINS=http://localhost:5173

# --- Phase 2 Backend (auth, db, throttler, mail) ---

# JWT Access Token secret (min 32 chars recommended for crypto strength)
JWT_ACCESS_SECRET=your-secret-key-min-32-chars-for-production

# JWT Access Token expiration time in seconds (default 900 = 15 minutes)
JWT_ACCESS_EXPIRES_IN=900

# JWT Refresh Token secret (min 32 chars recommended for crypto strength)
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars

# JWT Refresh Token expiration time in seconds (default 604800 = 7 days)
JWT_REFRESH_EXPIRES_IN=604800

# JWT Reset Password Token expiration time in seconds (default 3600 = 1 hour)
JWT_RESET_PASSWORD_EXPIRES_IN=3600

# Cookie secret for signed cookies (min 32 chars recommended)
COOKIE_SECRET=your-cookie-secret-min-32-chars

# Bcrypt rounds for password hashing (default 12, higher is slower but more secure)
BCRYPT_ROUNDS=12

# Global rate limiter TTL in seconds (default 60)
THROTTLE_GLOBAL_TTL=60

# Global rate limiter request limit per TTL (default 100)
THROTTLE_GLOBAL_LIMIT=100

# Auth endpoints rate limiter TTL in seconds (default 60)
THROTTLE_AUTH_TTL=60

# Auth endpoints rate limiter request limit per TTL (default 5, must be lower than global)
THROTTLE_AUTH_LIMIT=5

# Mail transport type: "console" (log to console), "stream" (for testing), or "smtp"
MAIL_TRANSPORT=console

# Email address to use as the "from" field in outgoing emails
MAIL_FROM=noreply@zonite.local

# SMTP server hostname (required when MAIL_TRANSPORT=smtp)
# MAIL_HOST=smtp.example.com

# SMTP server port (required when MAIL_TRANSPORT=smtp)
# MAIL_PORT=587

# SMTP authentication username (required when MAIL_TRANSPORT=smtp)
# MAIL_USER=your-email@example.com

# SMTP authentication password (required when MAIL_TRANSPORT=smtp)
# MAIL_PASS=your-app-password

# --- Frontend (apps/frontend) ---
# Base URL the frontend calls for API requests. Must include the /api prefix.
VITE_API_BASE_URL=http://localhost:3000/api

