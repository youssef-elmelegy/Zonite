{
  "name": "zonite",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node apps/backend/dist/main.js",
    "dev": "docker compose up --build",
    "dev:down": "docker compose down",
    "type-check": "pnpm -r --parallel run type-check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "prepare": "husky",
    "heroku-postbuild": "pnpm install --frozen-lockfile && pnpm --filter shared build && pnpm --filter backend build && pnpm --filter frontend build"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
